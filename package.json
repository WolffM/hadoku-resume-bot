{
  "name": "@wolffm/resume-bot",
  "version": "1.2.0",
  "description": "AI-powered conversational interface for interactive resume exploration",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WolffM/resume-bot.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/entry.d.ts",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./api": {
      "types": "./dist/worker.d.ts",
      "default": "./dist/worker.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config worker/vite.config.ts && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@wolffm/logger": ">=1.0.0",
    "@wolffm/task-ui-components": ">=1.0.0",
    "@wolffm/themes": ">=1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251230.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitejs/plugin-react": "^5.1.0",
    "@wolffm/logger": "^1.2.2",
    "@wolffm/task-ui-components": "^2.0.1",
    "@wolffm/themes": "^2.0.16",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "stylelint": "^17.12.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "typescript": "^5.6.3",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@wolffm/prefs-client": "^1.0.3",
    "hono": "^4.11.4",
    "openai": "^6.21.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.12"
  }
}
